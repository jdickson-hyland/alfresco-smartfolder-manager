<webscript>
    <shortname>Get Template Version</shortname>
    <description>Returns the JSON content of a specific historical version of a template</description>
    <url>/hyland/smartfolders/templates/{storeType}/{storeId}/{nodeId}/versions/{label}</url>
    <format default="json">extension</format>

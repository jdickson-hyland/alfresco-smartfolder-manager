<?xml version='1.0' encoding='UTF-8'?>
<beans xmlns="http://www.springframework.org/schema/beans"
       xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans
          http://www.springframework.org/schema/beans/spring-beans-3.0.xsd">

    <!-- ===== Services ===== -->

    <bean id="smartFolderModelService"
          class="com.hyland.alfresco.smartfoldermanager.service.SmartFolderModelServiceImpl">
        <property name="dictionaryService" ref="DictionaryService"/>
        <property name="namespaceService"  ref="NamespaceService"/>
    </bean>

    <bean id="smartFolderTemplateValidator"
          class="com.hyland.alfresco.smartfoldermanager.service.SmartFolderTemplateValidator">
        <property name="dictionaryService" ref="DictionaryService"/>
        <property name="namespaceService"  ref="NamespaceService"/>
    </bean>

    <bean id="smartFolderTemplateService"
          class="com.hyland.alfresco.smartfoldermanager.service.SmartFolderTemplateServiceImpl">
        <property name="nodeService"          ref="NodeService"/>
        <property name="contentService"       ref="ContentService"/>
        <property name="versionService"       ref="versionService"/>
        <property name="namespaceService"     ref="NamespaceService"/>
        <property name="transactionService"   ref="TransactionService"/>
    </bean>

    <!-- ===== Bootstrap ===== -->

    <bean id="smartFolderManagerBootstrap"
          class="com.hyland.alfresco.smartfoldermanager.bootstrap.SmartFolderManagerBootstrap"
          parent="module.baseComponent">
        <property name="moduleId"           value="alfresco-smartfolder-manager-platform"/>
        <property name="name"               value="SmartFolderManagerBootstrap"/>
        <property name="description"        value="Ensures the Smart Folder Templates folder exists in the Data Dictionary"/>
        <property name="sinceVersion"       value="1.0"/>
        <property name="appliesFromVersion" value="1.0"/>
        <property name="templateService"    ref="smartFolderTemplateService"/>
    </bean>

    <!-- ===== Web Scripts ===== -->
    <!-- Bean ID convention: webscript.<url-path-with-dots>.<method>
         Template variables {name} are replaced with the variable name in the bean ID. -->

    <bean id="webscript.hyland.smartfolders.models.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.ModelsListWebScript"
          parent="webscript">
        <property name="modelService" ref="smartFolderModelService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.model-classes.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.ModelClassesWebScript"
          parent="webscript">
        <property name="modelService" ref="smartFolderModelService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.class-properties.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.ClassPropertiesWebScript"
          parent="webscript">
        <property name="modelService" ref="smartFolderModelService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.templates.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplatesListWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.templates.post"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateCreateWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
        <property name="validator"       ref="smartFolderTemplateValidator"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateGetWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template.put"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateUpdateWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
        <property name="validator"       ref="smartFolderTemplateValidator"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template.delete"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateDeleteWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template-deploy.post"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateDeployWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template-undeploy.post"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateUndeployWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template-versions.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateVersionsWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.template-version.get"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateVersionGetWebScript"
          parent="webscript">
        <property name="templateService" ref="smartFolderTemplateService"/>
    </bean>

    <bean id="webscript.hyland.smartfolders.validate.post"
          class="com.hyland.alfresco.smartfoldermanager.webscript.TemplateValidateWebScript"
          parent="webscript">
        <property name="validator" ref="smartFolderTemplateValidator"/>
    </bean>

</beans>
